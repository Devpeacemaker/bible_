class SavedVerse {
  final String book;
  final int chapter;
  final int verse;
  final String text;

  SavedVerse({
    required this.book,
    required this.chapter,
    required this.verse,
    required this.text,
  });

  Map<String, dynamic> toJson() => {
        "book": book,
        "chapter": chapter,
        "verse": verse,
        "text": text,
      };

  factory SavedVerse.fromJson(Map<String, dynamic> json) {
    return SavedVerse(
      book: json["book"],
      chapter: json["chapter"],
      verse: json["verse"],
      text: json["text"],
    );
  }
}
