name: peace_m_bible
description: "A new Flutter project."
publish_to: 'none'

version: 1.0.0+1

environment:
  sdk: ^3.10.8

dependencies:
  flutter:
    sdk: flutter

  cupertino_icons: ^1.0.8
  shared_preferences: ^2.2.3
  uuid: ^4.5.1
  share_plus: ^11.0.0
  provider: ^6.1.5
  http: ^1.2.1
  hive: ^2.2.3
  hive_flutter: ^1.1.0
  just_audio: ^0.10.4

dev_dependencies:
  flutter_test:
    sdk: flutter

  flutter_lints: ^6.0.0
  flutter_launcher_icons: ^0.14.4

flutter:
  uses-material-design: true

  assets:
    - assets/bibles/
    - assets/images/

flutter_launcher_icons:
  android: true
  ios: true
  image_path: "assets/images/peace_m_logo.png"
  min_sdk_android: 21
